FROM debian:12-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends squid ca-certificates \
    && mkdir -p /var/log/squid /var/spool/squid /run/squid \
    && chown -R proxy:proxy /var/log/squid /var/spool/squid /run/squid \
    && rm -rf /var/lib/apt/lists/*

EXPOSE 3128

ENTRYPOINT ["squid"]
CMD ["-N", "-f", "/etc/squid/squid.conf"]
